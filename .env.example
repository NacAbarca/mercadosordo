# ============================================================
# MercadoSordo — Environment Configuration
# Copia a .env y ajusta los valores
# ============================================================

APP_NAME=MercadoSordo
APP_ENV=production
APP_DEBUG=false
APP_KEY=CHANGE_THIS_TO_RANDOM_64_CHAR_STRING
APP_URL=https://mercadosordo.cl

# ─── Database ──────────────────────────────────────────────
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=mercadosordo
DB_USER=ms_user
DB_PASS=SuperSecretPassword123!

# ─── Mail ──────────────────────────────────────────────────
MAIL_DRIVER=smtp
MAIL_HOST=smtp.mailtrap.io
MAIL_PORT=587
MAIL_USER=
MAIL_PASS=
MAIL_FROM=noreply@mercadosordo.cl
MAIL_FROM_NAME=MercadoSordo

# ─── Storage ───────────────────────────────────────────────
STORAGE_DRIVER=local     # local | s3
AWS_KEY=
AWS_SECRET=
AWS_BUCKET=mercadosordo
AWS_REGION=sa-east-1

# ─── Payment (WebPay / Transbank) ──────────────────────────
WEBPAY_COMMERCE_CODE=597055555532
WEBPAY_API_KEY=579B532A7440BB0C9079DED94D31EA1615BACEB29610EC55
WEBPAY_ENV=integration    # integration | production

# ─── Security ──────────────────────────────────────────────
CORS_ORIGIN=https://mercadosordo.cl
JWT_TTL_HOURS=168         # 7 days
SESSION_LIFETIME=120

# ─── Redis (optional for cache/queues) ─────────────────────
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASS=

# ─── Rate Limiting ─────────────────────────────────────────
RATE_LIMIT_PER_MINUTE=60
